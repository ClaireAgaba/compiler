// MiniLang: Fibonacci Sequence
// Demonstrates: recursion, functions, loops, conditionals

func fibonacci(n: int) -> int {
    if (n <= 1) {
        return n;
    }
    return fibonacci(n - 1) + fibonacci(n - 2);
}

func main() -> void {
    var limit: int = 10;
    var i: int = 0;

    print("Fibonacci Sequence:");
    while (i < limit) {
        print(fibonacci(i));
        i = i + 1;
    }
}
