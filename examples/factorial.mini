// MiniLang: Factorial Calculator
// Demonstrates: recursion, comparisons, arithmetic

func factorial(n: int) -> int {
    if (n <= 1) {
        return 1;
    }
    return n * factorial(n - 1);
}

func main() -> void {
    var i: int = 0;
    print("Factorial Table:");
    while (i <= 10) {
        print(factorial(i));
        i = i + 1;
    }
}
